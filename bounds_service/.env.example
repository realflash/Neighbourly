# Database Configuration
# DATABASE_URL is the primary connection string to the PostgreSQL database for the bounds service.
# If running locally using Docker, point this to your local PostgreSQL container.
# Format: postgres://username:password@hostname:port/database_name
DATABASE_URL="postgres://user:password@127.0.0.1:5432/neighbourly_uk"

# Google Maps API Key
# GOOGLE_MAPS_KEY is required to interact with Google Maps API for geocoding and map generation.
# Note: The bounds service will crash on startup if GOOGLE_MAPS_KEY is missing. 
# For local testing without a real key, you can set it to "dummy" to trigger a fallback image.
GOOGLE_MAPS_KEY="your_google_maps_key_here"

# Country Configuration
# COUNTRY defines the country code for the campaign and bounds logic.
# Examples: "UK" or "AU"
COUNTRY="UK"
