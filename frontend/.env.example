# Application Branding
# APP_NAME is displayed in the UI navigation and page titles
APP_NAME="Neighbourly"
# APP_DESCRIPTION is used for SEO and metadata tags
APP_DESCRIPTION="A turf-cutting tool for door-knocking campaigns"

# Security
# SECRET_KEY_BASE is used to cryptographically sign sessions and cookies. Ensure this is a long, random string in production.
SECRET_KEY_BASE="i.am.a.secret.key"

# External Integrations
# LAMBDA_BASE_URL specifies the endpoint for serverless AWS Lambda functions (e.g., for generating maps or handling geocoding)
LAMBDA_BASE_URL="https://4oqtu02x7f.execute-api.ap-southeast-2.amazonaws.com/prod"

# ZAP API Configuration
# ZAP_API is the authentication token or endpoint for external ZAP webhook integrations
ZAP_API=""
# ZAP_API_ON toggles the ZAP integration feature on ("True") or off ("False")
ZAP_API_ON="False"

# Database Configuration
# DB_URL is the primary connection string to the PostgreSQL database.
# Format: postgres://username:password@hostname:port/database_name
DB_URL="postgres://postgres:password@localhost:5433/neighbourly"

# Admin Definition
# ADMIN_EMAILS is a comma-separated list of admin email addresses allowed to manage campaigns and claims
ADMIN_EMAILS="admin@example.com,admin2@example.org"

# External Links
# CENTRALLY_COORDINATED_EVENTS_URL is the URL where users are directed to find and sign up for campaign events
CENTRALLY_COORDINATED_EVENTS_URL="https://www.example.com/events"