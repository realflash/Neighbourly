!!!
%html
  %head
    %title Edit Campaign
    %link{:rel => "stylesheet", :href => versioned_stylesheet('main')}
    %style
      :plain
        .campaign-card {
          background: rgba(255, 255, 255, 0.1);
          backdrop-filter: blur(10px);
          border: 1px solid rgba(255, 255, 255, 0.2);
          border-radius: 12px;
          padding: 20px;
          margin-bottom: 20px;
          box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .gradient-btn {
          background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
          color: white;
          border: none;
          padding: 10px 20px;
          border-radius: 8px;
          cursor: pointer;
          transition: transform 0.2s, box-shadow 0.2s;
        }
        .gradient-btn:hover {
          transform: translateY(-2px);
          box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }
        .form-control {
          width: 100%;
          padding: 10px;
          margin-top: 5px;
          margin-bottom: 15px;
          border-radius: 6px;
          border: 1px solid #ccc;
        }
        select[multiple] {
          height: 150px;
        }
  %body
    .container{:style => "padding: 40px; max-width: 800px; margin: 0 auto; font-family: 'Inter', sans-serif;"}
      %h1 Edit Campaign
      
      .campaign-card
        %form{:action => to("/admin/campaigns/#{@campaign.id}"), :method => "post"}
          %label{:for => "name"} Campaign Name:
          %input.form-control{:type => "text", :name => "name", :value => @campaign.name, :required => true}
          
          %label{:for => "type"} Campaign Type:
          %select.form-control{:name => "type"}
            %option{:value => "leafleting", :selected => @campaign.campaign_type == 'leafleting'} Leafleting
            %option{:value => "canvassing", :selected => @campaign.campaign_type == 'canvassing'} Canvassing
          %p.help-block{:style => "font-size: 0.85em; color: #ccc; margin-top: -10px; margin-bottom: 15px;"} Note: changing the type will change the PDFs generated.

          %label{:for => "ced_ids"} Select County Electoral Divisions (Hold Ctrl/Cmd to select multiple):
          %select.form-control{:name => "ced_ids[]", :multiple => true, :required => true}
            - campaign_ced_ids = @campaign.ceds.map(&:id)
            - @ceds.each do |ced|
              %option{:value => ced.id, :selected => campaign_ced_ids.include?(ced.id)}= ced.name
          
          %button.gradient-btn{:type => "submit"} Update Campaign
          %a{:href => to('/admin/campaigns'), :style => "margin-left: 15px; color: white;"} Cancel
