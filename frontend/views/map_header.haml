.container-fluid
  .panel-half-relative.panel-30.panel-pad-sides.padtopmore.padbottommore.logo-outer
    %a{href: to('/'), class: "logo-link"}
      %img.logo#logo-image{src: to('/images/map-logo.png')}
    - if authorised?
      %h2
        .welcome-container
          Hi
          .welcome-message #{user_name},
          %a#faqlink{href: to('/'), onclick: "return false;"}
            click here
          for more information about the doorknocking tool
  - if authorised?
    .panel-half-relative.panel-70.panel-pad-sides.padtopmore.padbottommore.form-outer
      %form#address_search_form
        .input-group
          %input#address_search.text.form-control{:autocomplete => "off", :placeholder => "Enter postcode", :type => "search"}
          .input-group-btn
            %button#postcode-button#address_search_button.btn.btn-custom.button-light-blue{:name => "search", :type => "submit"} Go To Postcode
        %select#campaign.form-control.half-width
          %option{:value => ""} -- Select a Campaign --
        %select#template.form-control.half-width
          - templates.each do |template|
            %option{value: template[:value]}= template[:label]
